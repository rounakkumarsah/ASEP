# =============================================================================
# ASEP — Autonomous Software Engineering Platform
# Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to version control.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development                  # development | staging | production
APP_NAME=ASEP
APP_VERSION=0.1.0
APP_LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true                      # Hot-reload (dev only)
APP_WORKERS=1                        # Uvicorn workers (production: set to CPU count)

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=asep
POSTGRES_USER=asep
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://asep:changeme@localhost:5432/asep

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Neo4j
# ---------------------------------------------------------------------------
NEO4J_HOST=localhost
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_URI=bolt://localhost:7687

# ---------------------------------------------------------------------------
# Qdrant
# ---------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ---------------------------------------------------------------------------
# Ollama
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
SECRET_KEY=change-this-to-a-random-256-bit-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
