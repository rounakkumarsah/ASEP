# ASEP Backend Environment Configuration
# Copy this file to .env for local development

# --------------------------------------------------
# Application
# --------------------------------------------------
APP_ENV=development
APP_PORT=8000
APP_RELOAD=true
APP_LOG_LEVEL=INFO

# --------------------------------------------------
# Security
# --------------------------------------------------
# IMPORTANT: Override these in production
SECRET_KEY=change-this-to-a-random-256-bit-secret
JWT_SECRET_KEY=change_me_in_production
JWT_REFRESH_SECRET_KEY=change_me_in_production_refresh

# --------------------------------------------------
# Database (PostgreSQL)
# --------------------------------------------------
DATABASE_URL=postgresql+asyncpg://asep:changeme@localhost:5432/asep

# --------------------------------------------------
# Redis (Caching & Task Queues)
# --------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --------------------------------------------------
# Neo4j (Graph Database)
# --------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --------------------------------------------------
# Qdrant (Vector Database)
# --------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --------------------------------------------------
# LLM Integration
# --------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# --------------------------------------------------
# Security & CORS
# --------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
